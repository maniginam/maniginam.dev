/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://westbatonrougechamber.chambermaster.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://region1.google-analytics.com https://westbatonrougechamber.chambermaster.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'

# Agent/bot discovery files — allow cross-origin fetch so agents can read them
/.well-known/*
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600

/openapi.json
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600
