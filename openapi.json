{
  "openapi": "3.1.0",
  "info": {
    "title": "maniginam.dev API",
    "version": "1.0.0",
    "description": "Public API for maniginam.dev (Gina Martiny / ManiGinaM, LLC)."
  },
  "servers": [{"url": "https://maniginam.dev"}],
  "paths": {
    "/api/subscribe": {
      "post": {
        "operationId": "subscribe",
        "summary": "Subscribe an email to the newsletter",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/SubscribeRequest"}
            }
          }
        },
        "responses": {
          "201": {"description": "Subscribed", "content": {"application/json": {"schema": {"type": "object", "properties": {"ok": {"type": "boolean"}}}}}},
          "400": {"description": "Invalid email"},
          "429": {"description": "Rate limited"}
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SubscribeRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {"type": "string", "format": "email", "description": "Subscriber email"},
          "name": {"type": "string", "description": "Optional name"},
          "source": {"type": "string", "maxLength": 60, "description": "Optional signup source"}
        }
      }
    }
  }
}
